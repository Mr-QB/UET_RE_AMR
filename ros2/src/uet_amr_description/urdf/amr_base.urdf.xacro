<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="uet_amr">

  <!-- ==================== Properties ==================== -->
  <xacro:property name="base_width"  value="0.40"/>  <!-- meters -->
  <xacro:property name="base_length" value="0.50"/>
  <xacro:property name="base_height" value="0.15"/>
  <xacro:property name="wheel_radius" value="0.065"/>
  <xacro:property name="wheel_width"  value="0.04"/>
  <xacro:property name="wheel_base"   value="0.35"/>
  <xacro:property name="caster_radius" value="0.025"/>

  <!-- ==================== Base Link ==================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.095" ixy="0.0" ixz="0.0"
               iyy="0.381" iyz="0.0"
               izz="0.476"/>
    </inertial>
  </link>

  <!-- ==================== Wheels ==================== -->
  <xacro:macro name="wheel" params="prefix x_offset y_offset">
    <link name="${prefix}_wheel">
      <visual>
        <geometry>
          <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
        </geometry>
        <material name="black">
          <color rgba="0.05 0.05 0.05 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.00051" ixy="0" ixz="0"
                 iyy="0.00051" iyz="0"
                 izz="0.00102"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel"/>
      <origin xyz="${x_offset} ${y_offset} 0" rpy="-1.5707 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="left"  x_offset="0" y_offset=" ${wheel_base/2}"/>
  <xacro:wheel prefix="right" x_offset="0" y_offset="-${wheel_base/2}"/>

  <!-- ==================== Sensors (included) ==================== -->
  <xacro:include filename="$(find uet_amr_description)/urdf/sensors.urdf.xacro"/>

</robot>
